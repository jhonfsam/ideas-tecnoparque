rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }

    // Validation Blueprint for FormularioSena
    function isValidFormularioSena(data) {
      return data.keys().hasAll(['id', 'createdAt', 'updatedAt', 'status', 'nombresCompletos', 'nombreIdea'])
        && data.id is string && data.id.size() <= 128
        && data.createdAt is string && data.createdAt.size() <= 100
        && data.updatedAt is string && data.updatedAt.size() <= 100
        && data.status is string && (data.status == 'draft' || data.status == 'pending' || data.status == 'synced')
        && data.nombresCompletos is string && data.nombresCompletos.size() <= 200
        && data.nombreIdea is string && data.nombreIdea.size() <= 300;
    }

    // Forms Collection Routing
    match /formularios/{formularioId} {
      allow read: if true;
      allow create: if isValidId(formularioId) && isValidFormularioSena(incoming());
      allow update: if isValidId(formularioId) && isValidFormularioSena(incoming());
      allow delete: if isValidId(formularioId);
    }
  }
}
